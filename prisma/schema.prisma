// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Pengqurban {
  id_pengqurban  String   @id @default(uuid())
  nkw            String   @unique 
  tanggal        DateTime @default(now())
  
  // Revisi Form: Langsung 1 kolom nama lengkap & nambah gender
  nama_lengkap   String
  jenis_kelamin  String?  // Isinya "L" atau "P"
  
  kd_wilayah     String? 
  no_urut        Int?
  alamat         String?  @db.Text
  telepon        String?
  
  // Relasi ke tabel PetugasJaga
  id_petugas     String?
  petugas        PetugasJaga? @relation(fields: [id_petugas], references: [id_petugas])

  // Relasi Hewan
  hewan_qurban   HewanQurban[]
  sapi_terpisah  SapiTerpisah[] 
}

model HewanQurban {
  id_hewan          String   @id @default(uuid())
  no_id_lama        String?  @unique
  nkw_pengqurban    String
  jenis_qurban      String 
  bentuk            String? 
  uang              Decimal? @db.Decimal(10, 2)
  nama_shohibul_sapi String? @db.Text
  
  biaya_operasional Decimal? @db.Decimal(10, 2)
  pindah_sapi       Boolean  @default(false)
  penyaluran_luar   Boolean  @default(false) // "Keluar ITS"
  metode_bayar      String?  // TUNAI / TRANSFER
  status_bayar      String   @default("BELUM LUNAS") // LUNAS / DP / BELUM LUNAS
  bukti_bayar       String?

  // --- FITUR BARU: STATUS Pemrosesan Hewan ---
  status_hewan      String   @default("MENUNGGU") 

  penyembelihan     String?
  melihat           Boolean  @default(false)
  menyembelih       Boolean  @default(false)
  jml_bagian        Int?
  pembagian         String?
  pesan_bagian      String?
  kel_sapi          String?
  no_uq             String?
  penyaluran        String?
  lokasi            String?
  keterangan        String?  @db.Text
  penerima          String?
  petugas           String?
  sebab             String?
  no_id_surat       String?
  opsi_pesan        String?   @default("PASRAH")
  pengambilan_pesan String?   @default("AMBIL")

  pengqurban Pengqurban  @relation(fields: [nkw_pengqurban], references: [nkw])
  permohonan Permohonan? @relation(fields: [no_id_surat], references: [no_id_surat])
}

model Permohonan {
  id_permohonan    String   @id @default(uuid())
  no_id_surat      String   @unique // NoIDSurat dari MS Access
  tanggal          DateTime @default(now())
  nomor_surat      String?
  nama_pemohon     String
  alamat_pemohon   String?  @db.Text
  kota_pemohon     String?
  no_kontak        String?
  penanggung_jawab String?
  no_rek           String?
  bank             String?
  atas_nama        String?

  // Relasi: Satu permohonan bisa terkait dengan banyak hewan qurban yang disalurkan
  hewan_disalurkan HewanQurban[]
}

model SapiTerpisah {
  id_sapi_terpisah String @id @default(uuid())
  no_id_lama       String @unique
  nkw_pengqurban   String
  nama             String
  kel_sapi         String
  no_uq            String

  // Relasi
  pengqurban Pengqurban @relation(fields: [nkw_pengqurban], references: [nkw])
}

model PetugasJaga {
  id_petugas String @id @default(uuid())
  id_lama    String @unique // IdPetugas dari MS Access
  nama       String
  no_hp      String?

  // Relasi (Wajib ditulis dua arah biar Prisma seneng)
  setoran    SetorPetugasJaga[]
  pengqurban Pengqurban[]
}

model SetorPetugasJaga {
  id_setor   String   @id @default(uuid())
  id_lama    String   @unique // IdSetor dari MS Access
  id_petugas String
  no_urut    Int?
  tanggal    DateTime @default(now())
  nama       String
  jml_setor  Decimal  @db.Decimal(10, 2)
  keterangan String?  @db.Text

  // Relasi
  petugas PetugasJaga @relation(fields: [id_petugas], references: [id_lama])
}

model KuitansiTaktis {
  id_kuitansi       String   @id @default(uuid())
  no_kw             String   @unique // NoKW dari MS Access
  tanggal           DateTime @default(now())
  penanggung_jawab  String

  // Relasi
  detail_kuitansi KuitansiTaktisDetail[]
}

model KuitansiTaktisDetail {
  id_detail  String  @id @default(uuid())
  no_kw      String
  pos        String?
  uraian     String? @db.Text
  debit      Decimal @default(0) @db.Decimal(12, 2)
  kredit     Decimal @default(0) @db.Decimal(12, 2)

  // Relasi
  kuitansi KuitansiTaktis @relation(fields: [no_kw], references: [no_kw])
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String   // Akan kita simpan dalam bentuk hash (bcrypt)
  nama      String   
  role      String   @default("STAF") // Bisa diisi: "ADMIN", "BENDAHARA", "STAF"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PermohonanOnline {
  id_permohonan      String   @id @default(uuid())
  tanggal_submit     DateTime @default(now())
  status             String   @default("BELUM_DICEK")

  // 👤 DATA SHOHIBUL
  nama_lengkap       String
  telepon            String?
  asal_wilayah       String?
  alamat             String?  @db.Text

  // 🐄 DATA HEWAN (JSON String)
  // Isinya nanti array: [{jenis, bentuk, nominal, melihat, menyembelih, penyaluran, pesan, dll}]
  daftar_hewan       String   @db.Text 

  // 💳 PEMBAYARAN
  total_pembayaran   Decimal  @db.Decimal(12, 2)
  bukti_bayar        String?  // URL/Nama file di Supabase
}